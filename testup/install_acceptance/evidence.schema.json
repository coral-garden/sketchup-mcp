{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/coral-garden/sketchup-mcp/testup/install_acceptance/evidence.schema.json",
  "title": "SketchUp MCP clean-install acceptance evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "kind",
    "status",
    "created_at",
    "producer",
    "run_id",
    "commit",
    "version",
    "operator",
    "dispatcher",
    "candidates",
    "artifacts"
  ],
  "properties": {
    "$schema": {"const": "evidence.schema.json"},
    "schema_version": {"const": 1},
    "kind": {"const": "sketchup_mcp.install_acceptance"},
    "status": {"const": "pass"},
    "created_at": {"type": "string", "format": "date-time"},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow", "github_run_id"],
      "properties": {
        "workflow": {"const": ".github/workflows/sketchup-runtime.yml"},
        "github_run_id": {"type": "integer", "minimum": 1}
      }
    },
    "run_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "version": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)+$"},
    "operator": {"type": "string", "minLength": 1},
    "dispatcher": {"type": "string", "minLength": 1},
    "candidates": {"type": "object"},
    "artifacts": {"type": "object", "minProperties": 1}
  }
}
