{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/coral-garden/sketchup-mcp/testup/production-adapter-evidence.schema.json",
  "title": "SketchUp MCP production adapter TestUp evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "run_id",
    "created_at",
    "attestation",
    "source",
    "runtime",
    "testup",
    "coverage",
    "raw_artifacts"
  ],
  "properties": {
    "schema_version": {"const": 3},
    "kind": {"const": "sketchup_mcp.production_adapter_testup"},
    "run_id": {"$ref": "#/$defs/sha256"},
    "created_at": {"type": "string", "format": "date-time"},
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "operator", "licensed_sketchup_confirmed", "single_testup_process_confirmed"],
      "properties": {
        "type": {"const": "manual"},
        "operator": {"type": "string", "minLength": 1},
        "licensed_sketchup_confirmed": {"const": true},
        "single_testup_process_confirmed": {"const": true}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit",
        "version",
        "rbz",
        "suite_sha256",
        "catalog_sha256",
        "commands",
        "installed_files"
      ],
      "properties": {
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "rbz": {"$ref": "#/$defs/artifact"},
        "suite_sha256": {"$ref": "#/$defs/sha256"},
        "catalog_sha256": {"$ref": "#/$defs/sha256"},
        "commands": {
          "type": "array",
          "minItems": 11,
          "maxItems": 11,
          "uniqueItems": true,
          "items": {"type": "string"}
        },
        "installed_files": {
          "type": "object",
          "minProperties": 2,
          "propertyNames": {"pattern": "^(?:su_mcp\\.rb|su_mcp/.+)$"},
          "additionalProperties": {"$ref": "#/$defs/sha256"}
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os_family",
        "os_version",
        "architecture",
        "sketchup_version",
        "testup_version",
        "ruby_version",
        "ruby_platform"
      ],
      "properties": {
        "os_family": {"enum": ["windows", "macos"]},
        "os_version": {"type": "string", "minLength": 1},
        "architecture": {"type": "string", "minLength": 1},
        "sketchup_version": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)+$"},
        "testup_version": {"const": "2.5.4"},
        "ruby_version": {"type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)+$"},
        "ruby_platform": {"type": "string", "minLength": 1}
      }
    },
    "testup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "total",
        "assertions",
        "passes",
        "failures",
        "errors",
        "skips",
        "test_class",
        "tests"
      ],
      "properties": {
        "status": {"const": "success"},
        "total": {"type": "integer", "minimum": 1},
        "assertions": {"type": "integer", "minimum": 1},
        "passes": {"type": "integer", "minimum": 1},
        "failures": {"const": 0},
        "errors": {"const": 0},
        "skips": {"const": 0},
        "test_class": {"const": "TC_ProductionAdapter"},
        "tests": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^test_[a-z0-9_]+$"}}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "scope", "source_sha256", "lines", "branches"],
      "properties": {
        "engine": {"const": "ruby Coverage"},
        "scope": {"const": ["su_mcp/sketchup_adapter.rb"]},
        "source_sha256": {"$ref": "#/$defs/sha256"},
        "lines": {"$ref": "#/$defs/exactCoverage"},
        "branches": {"$ref": "#/$defs/exactCoverage"}
      }
    },
    "raw_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_context",
        "testup_config",
        "testup_results",
        "testup_log",
        "testup_replay",
        "error_log",
        "runtime_report",
        "suite_marker"
      ],
      "properties": {
        "run_context": {"$ref": "#/$defs/rawArtifact"},
        "testup_config": {"$ref": "#/$defs/rawArtifact"},
        "testup_results": {"$ref": "#/$defs/rawArtifact"},
        "testup_log": {"$ref": "#/$defs/rawArtifact"},
        "testup_replay": {"$ref": "#/$defs/rawArtifact"},
        "error_log": {"$ref": "#/$defs/rawArtifact"},
        "runtime_report": {"$ref": "#/$defs/rawArtifact"},
        "suite_marker": {"$ref": "#/$defs/rawArtifact"}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "sha256"],
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "rawArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "sha256", "size"],
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size": {"type": "integer", "minimum": 0}
      }
    },
    "exactCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covered", "total", "percent", "missing"],
      "properties": {
        "covered": {"type": "integer", "minimum": 1},
        "total": {"type": "integer", "minimum": 1},
        "percent": {"const": 100.0},
        "missing": {"type": "array", "maxItems": 0}
      }
    }
  }
}
